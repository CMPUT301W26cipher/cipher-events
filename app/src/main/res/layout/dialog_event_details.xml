<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@drawable/rounded_white_bg"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center_horizontal">


    <TextView
        android:id="@+id/detail_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Event title"
        android:paddingBottom="8dp"
        android:textSize="22sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/detail_attendees"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="# of people in waitlist"
        android:paddingBottom="12dp"
        android:textSize="16sp" />

    <TextView
        android:id="@+id/date_location_tag"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingTop="16dp"
        android:text="Date &amp; Location"
        android:textSize="16sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/detail_date_location"
        android:hint="date, location"
        android:textSize="15sp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:paddingBottom="16dp" />

    <TextView
        android:id="@+id/detail_tags_label"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingTop="16dp"
        android:text="Tags"
        android:textSize="16sp"
        android:textStyle="bold" />

    <LinearLayout
        android:id="@+id/detail_tags_container"
        android:hint="tags"
        android:orientation="horizontal"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content" />

    <TextView
        android:id="@+id/detail_lottery_header"
        android:text="Lottery Guidelines"
        android:textStyle="bold"
        android:textSize="16sp"
        android:paddingTop="20dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content" />

    <TextView
        android:id="@+id/detail_lottery_text"
        android:textSize="14sp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingTop="6dp"
        android:lineSpacingExtra="4dp"
        tools:text="Placeholder guidelines text for preview." />

    <Button
        android:id="@+id/scan_button"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:padding="12dp"
        android:text="Scan Info"
        android:textColor="@android:color/white"
        android:textSize="16sp"
        android:textStyle="bold" />



</LinearLayout>