<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:fadeScrollbars="false"
    android:scrollbarStyle="outsideOverlay"
    android:scrollbars="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/rounded_white_bg"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:id="@+id/detail_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Event title"
            android:paddingBottom="8dp"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/detail_attendees"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="# of people in waitlist"
            android:paddingBottom="12dp"
            android:textSize="16sp" />

        <ImageView
            android:id="@+id/detail_banner"
            android:layout_width="match_parent"
            android:layout_height="180dp"
            android:layout_marginBottom="16dp"
            android:scaleType="centerCrop"
            android:src="@drawable/gray_placeholder"
            android:visibility="gone" />

        <TextView
            android:id="@+id/date_location_tag"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingTop="16dp"
            android:text="Date &amp; Location"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/detail_date_location"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:hint="date, location"
            android:paddingBottom="16dp"
            android:textSize="15sp" />

        <TextView
            android:id="@+id/description_label"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingTop="16dp"
            android:text="Description"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/detail_description"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="description"
            android:paddingBottom="12dp"
            android:textSize="16sp" />


        <TextView
            android:id="@+id/detail_tags_label"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingTop="16dp"
            android:text="Tags"
            android:textSize="16sp"
            android:textStyle="bold" />

        <LinearLayout
            android:id="@+id/detail_tags_container"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:hint="tags"
            android:orientation="horizontal" />

        <TextView
            android:id="@+id/detail_lottery_header"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingTop="20dp"
            android:text="Lottery Guidelines"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/detail_lottery_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:lineSpacingExtra="4dp"
            android:paddingTop="6dp"
            android:textSize="14sp"
            tools:text="Placeholder guidelines text for preview." />

        <Button
            android:id="@+id/notify_button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="Send Notification"
            android:visibility="gone" />

        <Button
            android:id="@+id/scan_button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:padding="12dp"
            android:text="Scan Info"
            android:textColor="@android:color/white"
            android:textSize="16sp"
            android:textStyle="bold" />

    </LinearLayout>
</ScrollView>