<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/dialog_bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Banner with Rounded Corners and Close Button -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="200dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp"
            android:layout_marginBottom="16dp">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <ImageView
                    android:id="@+id/detail_banner"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:src="@drawable/gray_placeholder" />

                <ImageView
                    android:id="@+id/btn_favorite"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_gravity="top|start"
                    android:layout_margin="12dp"
                    android:padding="8dp"
                    android:background="@drawable/button_background_purple"
                    android:backgroundTint="#88454261"
                    android:src="@drawable/baseline_star_border_24"
                    app:tint="@color/white" />

                <ImageView
                    android:id="@+id/btn_close"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_gravity="top|end"
                    android:layout_margin="12dp"
                    android:padding="8dp"
                    android:background="@drawable/button_background_purple"
                    android:backgroundTint="#88454261"
                    android:src="@drawable/baseline_close_24"
                    app:tint="@color/white" />
            </FrameLayout>
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:id="@+id/organizer_badge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/input_bg"
            android:backgroundTint="@color/role_organizer"
            android:paddingHorizontal="12dp"
            android:paddingVertical="4dp"
            android:text="Organizer Mode"
            android:textColor="@color/black"
            android:textSize="10sp"
            android:textStyle="bold"
            android:textAllCaps="true"
            android:layout_marginBottom="8dp"
            android:visibility="gone"
            tools:visibility="visible"/>

        <TextView
            android:id="@+id/detail_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/white"
            android:textSize="24sp"
            android:textStyle="bold"
            tools:text="Event Title" />

        <TextView
            android:id="@+id/detail_attendees"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/text_hint"
            android:textSize="14sp"
            android:layout_marginTop="4dp"
            tools:text="120 people in waitlist" />

        <!-- Organizer Stats Card -->
        <LinearLayout
            android:id="@+id/organizer_stats_card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="16dp"
            android:padding="16dp"
            android:background="@drawable/input_bg"
            android:visibility="gone"
            tools:visibility="visible">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">
                <TextView
                    android:id="@+id/tv_stats_waitlist"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/white"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    tools:text="120" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Waitlist"
                    android:textColor="@color/text_hint"
                    android:textSize="10sp"
                    android:textAllCaps="true"
                    android:textStyle="bold"/>
            </LinearLayout>

            <View
                android:layout_width="1dp"
                android:layout_height="match_parent"
                android:background="#1AFFFFFF"
                android:layout_marginHorizontal="16dp"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">
                <TextView
                    android:id="@+id/tv_stats_capacity"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/white"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    tools:text="∞" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Capacity"
                    android:textColor="@color/text_hint"
                    android:textSize="10sp"
                    android:textAllCaps="true"
                    android:textStyle="bold"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Organizer Section -->
        <LinearLayout
            android:id="@+id/organizer_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="16dp">

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/organizer_image"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:scaleType="centerCrop"
                android:src="@drawable/gray_placeholder"
                app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Full"
                app:strokeWidth="1dp"
                app:strokeColor="#33FFFFFF"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="14dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ORGANIZER"
                    android:textColor="@color/text_hint"
                    android:textSize="9sp"
                    android:fontFamily="sans-serif-black"
                    android:letterSpacing="0.1" />

                <TextView
                    android:id="@+id/organizer_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/white"
                    android:textSize="17sp"
                    android:fontFamily="sans-serif-black"
                    tools:text="Organizer Name" />
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/message_button"
                style="@style/Widget.Material3.Button.TonalButton"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:minHeight="0dp"
                android:text="Message"
                android:textSize="12sp"
                android:fontFamily="sans-serif-medium"
                app:cornerRadius="10dp"
                app:backgroundTint="#15FFFFFF"
                android:textColor="@color/white"
                app:icon="@drawable/ic_message_24"
                app:iconSize="14dp"
                app:iconTint="@color/white"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:paddingHorizontal="12dp" />
        </LinearLayout>

        <!-- Date and Location Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="16dp"
            android:padding="12dp"
            android:background="@drawable/input_bg">

            <TextView
                android:id="@+id/date_location_tag"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Date &amp; Location"
                android:textColor="@color/text_label"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textAllCaps="true" />

            <TextView
                android:id="@+id/detail_date_location"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/white"
                android:textSize="15sp"
                android:layout_marginTop="4dp"
                tools:text="Dec 12, 2023 - Edmonton" />
        </LinearLayout>

        <!-- Description Section -->
        <TextView
            android:id="@+id/description_label"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="About this Event"
            android:textColor="@color/white"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/detail_description"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:textColor="@color/text_label"
            android:textSize="15sp"
            android:lineSpacingExtra="4dp"
            tools:text="This is a detailed description of the event. It can span multiple lines and should be easy to read." />

        <!-- Tags Section -->
        <TextView
            android:id="@+id/detail_tags_label"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="Tags"
            android:textColor="@color/white"
            android:textSize="18sp"
            android:textStyle="bold" />

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/detail_tags_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            app:chipSpacingHorizontal="8dp"
            app:chipSpacingVertical="4dp" />

        <!-- Lottery Guidelines -->
        <LinearLayout
            android:id="@+id/lottery_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="20dp"
            android:padding="14dp"
            android:background="@drawable/input_bg">

            <TextView
                android:id="@+id/detail_lottery_header"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Lottery Guidelines"
                android:textColor="@color/role_admin"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/detail_lottery_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:textColor="@color/text_label"
                android:textSize="14sp"
                android:lineSpacingExtra="2dp"
                tools:text="Lottery details go here..." />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="20dp"
            android:background="#1AFFFFFF" />

        <!-- Comments Section -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Comments"
            android:textColor="@color/white"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="12dp"/>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_comments"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="100dp"
            android:nestedScrollingEnabled="false"
            tools:listitem="@layout/item_event_comment" />

        <!-- Leave a Comment -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="16dp"
            android:padding="12dp"
            android:background="@drawable/input_bg">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Join the Conversation"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp"/>

            <EditText
                android:id="@+id/et_comment_input"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Share your thoughts..."
                android:textColorHint="@color/text_hint"
                android:textColor="@color/white"
                android:background="@android:color/transparent"
                android:inputType="textMultiLine"
                android:minLines="2"
                android:maxLines="4"
                android:gravity="top"
                android:padding="4dp"
                android:textSize="14sp"/>

            <TextView
                android:id="@+id/tv_comment_error"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/remove_red"
                android:textSize="12sp"
                android:visibility="gone"
                android:layout_marginTop="4dp"
                tools:text="Comment cannot be empty" />

            <Button
                android:id="@+id/btn_post_comment"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end"
                android:text="Post"
                android:backgroundTint="@color/button_purple"
                android:textColor="@color/white"
                android:layout_marginTop="8dp"
                android:textAllCaps="false"
                style="@style/Widget.Material3.Button.TonalButton"/>
        </LinearLayout>

        <!-- Organizer Actions Dashboard -->
        <LinearLayout
            android:id="@+id/organizer_action_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:background="@drawable/input_bg"
            android:backgroundTint="#1A81C784"
            android:layout_marginTop="24dp"
            android:visibility="gone"
            tools:visibility="visible">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Organizer Dashboard"
                android:textColor="@color/role_organizer"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textAllCaps="true"
                android:layout_marginBottom="16dp"
                android:letterSpacing="0.1"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/organizer_view_waitlist_button"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Manage Waiting List"
                android:backgroundTint="@color/role_organizer"
                android:textColor="@color/black"
                android:textStyle="bold"
                app:cornerRadius="12dp"
                app:icon="@drawable/outline_account_circle_24"
                app:iconGravity="textStart"
                app:iconPadding="12dp"
                app:iconTint="@color/black" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/organizer_view_map_button"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="12dp"
                android:text="View Event Map"
                android:backgroundTint="#33FFFFFF"
                android:textColor="@color/white"
                android:textStyle="bold"
                app:cornerRadius="12dp"
                app:icon="@drawable/baseline_home_24"
                app:iconGravity="textStart"
                app:iconPadding="12dp"
                app:iconTint="@color/white" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="12dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/notify_button"
                    style="@style/Widget.Material3.Button.TonalButton"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    android:text="Notify"
                    android:textColor="@color/white"
                    app:backgroundTint="#33FFFFFF"
                    app:cornerRadius="12dp"
                    app:icon="@drawable/baseline_notifications_24"
                    app:iconPadding="4dp"
                    app:iconTint="@color/white" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/organizer_message_button"
                    style="@style/Widget.Material3.Button.TonalButton"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    android:text="Messages"
                    android:textColor="@color/white"
                    app:backgroundTint="#33FFFFFF"
                    app:cornerRadius="12dp"
                    app:icon="@drawable/ic_message_24"
                    app:iconPadding="4dp"
                    app:iconTint="@color/white" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="12dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/edit_event_button"
                    style="@style/Widget.Material3.Button.TonalButton"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    android:text="Edit Details"
                    android:textColor="@color/white"
                    app:backgroundTint="#33FFFFFF"
                    app:cornerRadius="12dp"
                    app:icon="@drawable/ic_edit_24"
                    app:iconPadding="4dp"
                    app:iconTint="@color/white" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/delete_event_button"
                    style="@style/Widget.Material3.Button.TonalButton"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    android:text="Delete"
                    android:textColor="@color/remove_red"
                    app:backgroundTint="#22FF5252"
                    app:cornerRadius="12dp"
                    app:icon="@drawable/baseline_close_24"
                    app:iconPadding="4dp"
                    app:iconTint="@color/remove_red" />
            </LinearLayout>
        </LinearLayout>

        <!-- Entrant Actions Section -->
        <LinearLayout
            android:id="@+id/entrant_action_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <Button
                android:id="@+id/scan_button"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="20dp"
                android:text="Join Waitlist"
                android:backgroundTint="@color/button_purple"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:textStyle="bold"
                app:cornerRadius="12dp" />
        </LinearLayout>

        <Button
            android:id="@+id/btn_close_bottom"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="20dp"
            android:text="Close"
            android:backgroundTint="#2A2A3C"
            android:textColor="@color/white"
            android:textStyle="bold"
            app:cornerRadius="12dp" />

        <!-- Added some bottom padding for better scroll feel -->
        <View
            android:layout_width="match_parent"
            android:layout_height="20dp" />

    </LinearLayout>
</ScrollView>