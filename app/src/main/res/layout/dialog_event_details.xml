<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/dialog_bg"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Banner with Rounded Corners -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="200dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            android:layout_marginBottom="16dp">

            <ImageView
                android:id="@+id/detail_banner"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/gray_placeholder" />
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:id="@+id/detail_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/white"
            android:textSize="26sp"
            android:textStyle="bold"
            tools:text="Event Title" />

        <TextView
            android:id="@+id/detail_attendees"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/text_hint"
            android:textSize="14sp"
            android:layout_marginTop="4dp"
            tools:text="120 people in waitlist" />

        <!-- Date and Location Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="16dp"
            android:padding="12dp"
            android:background="@drawable/input_bg">

            <TextView
                android:id="@+id/date_location_tag"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Date &amp; Location"
                android:textColor="@color/text_label"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textAllCaps="true" />

            <TextView
                android:id="@+id/detail_date_location"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:layout_marginTop="4dp"
                tools:text="Dec 12, 2023 - Edmonton" />
        </LinearLayout>

        <!-- Description Section -->
        <TextView
            android:id="@+id/description_label"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="About this Event"
            android:textColor="@color/white"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/detail_description"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textColor="@color/text_label"
            android:textSize="15sp"
            android:lineSpacingExtra="4dp"
            tools:text="This is a detailed description of the event. It can span multiple lines and should be easy to read." />

        <!-- Tags Section -->
        <TextView
            android:id="@+id/detail_tags_label"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="Tags"
            android:textColor="@color/white"
            android:textSize="18sp"
            android:textStyle="bold" />

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/detail_tags_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            app:chipSpacingHorizontal="8dp"
            app:chipSpacingVertical="4dp" />

        <!-- Lottery Guidelines -->
        <LinearLayout
            android:id="@+id/lottery_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="20dp"
            android:padding="16dp"
            android:background="@drawable/input_bg">

            <TextView
                android:id="@+id/detail_lottery_header"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Lottery Guidelines"
                android:textColor="@color/role_admin"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/detail_lottery_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:textColor="@color/text_label"
                android:textSize="14sp"
                android:lineSpacingExtra="2dp"
                tools:text="Lottery details go here..." />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="24dp"
            android:background="@color/input_background" />

        <!-- Comments Section -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Comments"
            android:textColor="@color/white"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="12dp"/>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_comments"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="100dp"
            android:nestedScrollingEnabled="false"
            tools:listitem="@layout/item_event_comment" />

        <!-- Leave a Comment -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="20dp"
            android:padding="12dp"
            android:background="@drawable/input_bg">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Join the Conversation"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp"/>

            <EditText
                android:id="@+id/et_comment_input"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Share your thoughts..."
                android:textColorHint="@color/text_hint"
                android:textColor="@color/white"
                android:background="@android:color/transparent"
                android:inputType="textMultiLine"
                android:minLines="2"
                android:maxLines="4"
                android:gravity="top"
                android:padding="4dp"
                android:textSize="14sp"/>

            <TextView
                android:id="@+id/tv_comment_error"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/remove_red"
                android:textSize="12sp"
                android:visibility="gone"
                android:layout_marginTop="4dp"
                tools:text="Comment cannot be empty" />

            <Button
                android:id="@+id/btn_post_comment"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end"
                android:text="Post"
                android:backgroundTint="@color/button_purple"
                android:textColor="@color/white"
                android:layout_marginTop="8dp"
                style="@style/Widget.Material3.Button.TonalButton"/>
        </LinearLayout>

        <!-- Action Buttons -->
        <Button
            android:id="@+id/notify_button"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="24dp"
            android:text="Send Notification"
            android:backgroundTint="@color/role_organizer"
            android:textColor="@color/black"
            android:textStyle="bold"
            app:cornerRadius="12dp"
            android:visibility="gone" />

        <Button
            android:id="@+id/scan_button"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="16dp"
            android:text="Join Waitlist"
            android:backgroundTint="@color/button_purple"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:textStyle="bold"
            app:cornerRadius="12dp" />

        <!-- Added some bottom padding for better scroll feel -->
        <View
            android:layout_width="match_parent"
            android:layout_height="24dp" />

    </LinearLayout>
</ScrollView>