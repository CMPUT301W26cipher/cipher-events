<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/dialog_background"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="24dp">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/profileImageCard"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:layout_marginTop="32dp"
            app:cardCornerRadius="60dp"
            app:cardElevation="8dp"
            app:strokeWidth="3dp"
            app:strokeColor="@color/button_purple"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <ImageView
                android:id="@+id/admin_profile_image"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/outline_account_circle_24"
                app:tint="@color/white"
                android:padding="24dp"
                android:background="@color/input_background"/>
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:id="@+id/admin_profile_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Admin Name"
            android:textColor="@color/white"
            android:textSize="24sp"
            android:textStyle="bold"
            app:layout_constraintTop_toBottomOf="@id/profileImageCard"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/admin_profile_email"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="admin@example.com"
            android:textColor="@color/text_hint"
            android:textSize="14sp"
            app:layout_constraintTop_toBottomOf="@id/admin_profile_name"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/admin_profile_phone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Phone Number"
            android:textColor="@color/text_hint"
            android:textSize="14sp"
            app:layout_constraintTop_toBottomOf="@id/admin_profile_email"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Edit Form (Hidden by default) -->
        <EditText android:id="@+id/admin_profile_name_edit" android:layout_width="wrap_content" android:layout_height="wrap_content" android:visibility="gone" tools:ignore="MissingConstraints" />
        <EditText android:id="@+id/admin_profile_email_edit" android:layout_width="wrap_content" android:layout_height="wrap_content" android:visibility="gone" tools:ignore="MissingConstraints" />
        <EditText android:id="@+id/admin_profile_phone_edit" android:layout_width="wrap_content" android:layout_height="wrap_content" android:visibility="gone" tools:ignore="MissingConstraints" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/admin_history_btn"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="40dp"
            android:text="Admin History"
            android:textAllCaps="false"
            android:textSize="16sp"
            app:cornerRadius="12dp"
            app:backgroundTint="@color/button_purple"
            app:layout_constraintTop_toBottomOf="@id/admin_profile_phone" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/admin_edit_profile_btn"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="8dp"
            android:text="Detailed Profile Settings"
            android:textAllCaps="false"
            android:textColor="@color/white"
            app:layout_constraintTop_toBottomOf="@id/admin_history_btn" />

        <View
            android:id="@+id/divider"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="24dp"
            android:background="#30FFFFFF"
            app:layout_constraintTop_toBottomOf="@id/admin_edit_profile_btn" />

        <TextView
            android:id="@+id/role_management_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:text="Role Management"
            android:textColor="@color/white"
            android:textSize="18sp"
            android:textStyle="bold"
            app:layout_constraintTop_toBottomOf="@id/divider"
            app:layout_constraintStart_toStartOf="parent" />

        <!-- Entrant Role Card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/entrantRoleCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:cardBackgroundColor="@color/input_background"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp"
            app:layout_constraintTop_toBottomOf="@id/role_management_title">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Entrant Portal"
                    android:textColor="@color/white"
                    android:textStyle="bold"
                    android:textSize="16sp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Manage events as an attendee"
                    android:textColor="@color/text_hint"
                    android:textSize="12sp"
                    android:layout_marginBottom="16dp"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_enable_entrant_role"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="Enable Entrant Mode"
                    android:textAllCaps="false"
                    app:cornerRadius="8dp"
                    app:backgroundTint="#2196F3" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_disable_entrant_role"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="Disable Entrant Mode"
                    android:textAllCaps="false"
                    app:cornerRadius="8dp"
                    app:backgroundTint="#FF5252" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Organizer Role Card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/organizerRoleCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            app:cardBackgroundColor="@color/input_background"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp"
            app:layout_constraintTop_toBottomOf="@id/entrantRoleCard">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Organizer Portal"
                    android:textColor="@color/white"
                    android:textStyle="bold"
                    android:textSize="16sp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Create and manage your own events"
                    android:textColor="@color/text_hint"
                    android:textSize="12sp"
                    android:layout_marginBottom="16dp"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_enable_organizer_role"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="Enable Organizer Mode"
                    android:textAllCaps="false"
                    app:cornerRadius="8dp"
                    app:backgroundTint="#4CAF50" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_disable_organizer_role"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="Disable Organizer Mode"
                    android:textAllCaps="false"
                    app:cornerRadius="8dp"
                    app:backgroundTint="#FF5252" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/admin_signout_btn"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="48dp"
            android:layout_marginBottom="40dp"
            android:text="Sign Out"
            android:textAllCaps="false"
            android:textColor="@color/white"
            app:cornerRadius="12dp"
            app:strokeColor="@color/button_purple"
            app:strokeWidth="2dp"
            app:layout_constraintTop_toBottomOf="@id/organizerRoleCard"
            app:layout_constraintBottom_toBottomOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>