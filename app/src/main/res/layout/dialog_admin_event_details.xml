<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/rounded_white_bg"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:id="@+id/admin_detail_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="8dp"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@color/text_label"
            android:text="Event Title" />

        <TextView
            android:id="@+id/admin_detail_waitlist_count"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="12dp"
            android:textSize="16sp"
            android:textColor="@color/text_hint"
            android:text="0 people in waitlist" />

        <!-- Banner container with delete icon -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="180dp"
            android:layout_marginBottom="16dp">

            <ImageView
                android:id="@+id/admin_detail_banner"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/gray_placeholder" />

            <ImageView
                android:id="@+id/admin_delete_banner_icon"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_gravity="top|end"
                android:layout_margin="8dp"
                android:padding="4dp"
                android:background="@drawable/rounded_white_bg"
                android:src="@drawable/baseline_close_24" />
        </FrameLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingTop="16dp"
            android:text="Date &amp; Location"
            android:textSize="16sp"
            android:textColor="@color/text_label"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/admin_detail_date_location"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="16dp"
            android:textSize="15sp"
            android:textColor="@color/text_hint"
            android:text="Date, Location" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingTop="16dp"
            android:text="Description"
            android:textSize="16sp"
            android:textColor="@color/text_label"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/admin_detail_description"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="12dp"
            android:textSize="16sp"
            android:textColor="@color/text_hint"
            android:text="Event description goes here..." />

        <Button
            android:id="@+id/admin_btn_remove_event"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:backgroundTint="#FF5252"
            android:text="Remove Event"
            android:textColor="@android:color/white"
            android:textStyle="bold" />

    </LinearLayout>
</ScrollView>